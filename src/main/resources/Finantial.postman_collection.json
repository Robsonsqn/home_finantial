									"const jsonData = pm.response.json();\r",
									"if (jsonData && jsonData.token) {\r",
									"  pm.globals.set(\"TOKEN\", jsonData.token);\r",
									"  pm.test(\"Token salvo\", () => pm.expect(jsonData.token).to.be.a(\"string\"));\r",
									"} else {\r",
									"  pm.test(\"Nenhum token retornado\", () => pm.expect(jsonData.token).to.exist);\r",
